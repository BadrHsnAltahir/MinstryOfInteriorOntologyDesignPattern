<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#"
     xml:base="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl">
        <rdfs:comment xml:lang="ar">انطلوجيا الحكومة الالكترونية السودانية - الخدمات التي تقدمها وزارة الداخلية للمواطنين عبر مجمعات خدمة الجمهور .
هذه الانطلوجيا تم تطويرها من قبل الباحث بدرالدين حسن الطاهر لنيل درجة الدكتوراة في نظم المعلومات من جامعة النيلين في السودان الخرطوم</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Own -->

    <owl:ObjectProperty rdf:about="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Own">
        <owl:inverseOf rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#OwnedBy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Citizen"/>
        <rdfs:range rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Vehicle"/>
        <rdfs:range rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Weapon"/>
        <rdfs:label xml:lang="ar">يملك</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#OwnedBy -->

    <owl:ObjectProperty rdf:about="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#OwnedBy">
        <rdfs:label xml:lang="ar">مملوك ل</rdfs:label>
    </owl:ObjectProperty>
    


