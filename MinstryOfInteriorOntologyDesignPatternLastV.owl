    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Asset -->

    <owl:Class rdf:about="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Asset">
        <rdfs:subClassOf rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#MInistryOfInterior"/>
        <rdfs:comment xml:lang="ar">الاصول والممتلكات تمثل هذه الفئة جميع الاصول والممتلكات التي يمكن للمواطن امتلاكها وتسجيلها عبر وزارة الداخلية مثل المركبات والاسلحة</rdfs:comment>
        <rdfs:label xml:lang="ar">الاصول والممتلكات</rdfs:label>
    </owl:Class>
    


    <!-- http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#BackgroundCheck -->

    <owl:Class rdf:about="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#BackgroundCheck">
        <rdfs:subClassOf rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#CriminalEvidence"/>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#hasNationalNumber"/>
        </owl:hasKey>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#hasCheckNumber"/>
        </owl:hasKey>
        <rdfs:comment xml:lang="ar">وثيقة تفيد بالحالة الامنية وخلفية الجرائم للمواطن ، وتعمل كشهادة حسن سير وسلوك</rdfs:comment>
        <rdfs:label xml:lang="ar">الفحص الامني</rdfs:label>
        <rdfs:label xml:lang="ar">الفيش والتفييش</rdfs:label>
    </owl:Class>
    


