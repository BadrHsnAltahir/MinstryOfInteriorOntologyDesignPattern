                <owl:someValuesFrom rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#BackgroundCheck"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#hasBirthCertificate"/>
                <owl:allValuesFrom rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#BirthCertificate"/>
