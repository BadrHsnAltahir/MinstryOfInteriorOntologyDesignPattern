            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.sudan-government.com/ontologies/mistryofinteriorontology.owl#Asset"/>
        <rdfs:label xml:lang="ar">سلاح</rdfs:label>
